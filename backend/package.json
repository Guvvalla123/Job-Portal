{
  "name": "job-portal-backend",
  "version": "1.0.0",
  "description": "Production-ready backend for MERN job portal - enterprise-grade API",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "worker:email": "node src/workers/emailWorker.js",
    "worker:job-alert-digest": "node src/workers/jobAlertDigestWorker.js",
    "migrate:resume-cloudinary-access": "node scripts/updateResumeAccessMode.js",
    "test": "cross-env NODE_ENV=test jest --coverage --forceExit --runInBand",
    "test:watch": "cross-env NODE_ENV=test jest --watch --forceExit",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --ext .js --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\""
  },
  "keywords": [
    "mern",
    "job-portal",
    "express",
    "mongodb",
    "api",
    "production"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@sentry/node": "^8.55.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.0",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.2",
    "opossum": "^8.1.2",
    "otplib": "^12.0.1",
    "prom-client": "^15.1.3",
    "uuid": "^11.0.3",
    "winston": "^3.17.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js",
      "!src/**/__tests__/**",
      "!src/config/logger.js"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "forceExit": true,
    "testTimeout": 120000,
    "maxWorkers": 1
  }
}
